#!/bin/sh

# exclude these files from creating links
EXCLUDE="^.git$|^.gitignore$|^README.md|^vim.d|^dot.claude$"

usage() {
  echo "Please run this script from 'dotmatrix' directory!"
  echo "Usage:  ./bin/dotmatrix-install"
	exit
}

pwd=`pwd`
if [ `basename ${pwd}` != 'dotmatrix' ] ; then
  usage
fi

# self update
git pull
# install/update vim plugins via vim-plug
echo "===== vim-plug ====="
vim -u ~/.vim/vim-plugrc --noplugin +PlugUpgrade +PlugInstall +PlugUpdate +qall

#for i in `find . -depth 1 -exec basename {} \;`; do
for i in `find . -maxdepth 1 -exec basename {} \;`; do
  echo ${i} | egrep ${EXCLUDE} 1> /dev/null && echo "skipping ${i}" &&  continue
  if [ -f ${HOME}/${i} -o -d ${HOME}/${i} -o -L  ${HOME}/${i} ]; then
    #echo "${HOME}/${i} already exists" && ls -ald ${HOME}/${i}
    ls -ald ${HOME}/${i} | awk '{ print $9,$10,$11 }' | grep -v ${pwd}
		continue
  fi
  ln -vs ${pwd}/$i ${HOME}/$i
done

# .config directory
if [ -d .config ]; then
	echo "===== .config/ ====="
	for i in `find .config -mindepth 1 -maxdepth 1 -type d`; do
	#	echo "> ${i}"
		if [ -d ${HOME}/${i} ] ; then
			echo "${HOME}/$i already exists"
			continue
		fi
		ln -vs ${pwd}/$i ${HOME}/$i
	done
fi

# dot.claude -> ~/.claude (link contents, not the directory itself)
if [ -d dot.claude ]; then
	echo "===== .claude/ ====="
	mkdir -p ${HOME}/.claude
	for i in `find dot.claude -mindepth 1 -maxdepth 1`; do
		name=`basename $i`
		target="${HOME}/.claude/${name}"
		if [ -f ${target} -o -d ${target} -o -L ${target} ]; then
			ls -ald ${target} | awk '{ print $9,$10,$11 }' | grep -v ${pwd}
			continue
		fi
		ln -vs ${pwd}/$i ${target}
	done
fi
